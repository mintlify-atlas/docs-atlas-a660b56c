  "keyFeatures": [
    "Markdown-based content with Liquid templating for versioning and conditional rendering",
    "Multi-version documentation supporting GitHub.com, GitHub Enterprise Server, and GitHub Enterprise Cloud",
    "Automated REST, GraphQL, and Webhook API documentation pipelines from OpenAPI specs",
    "Full-text search powered by Elasticsearch",
    "Content linting with markdownlint and custom rules to enforce style and quality",
    "Internationalization with automated translation workflows across multiple languages",
    "Next.js/Express server with dynamic content generation and HTTP redirects",
    "GitHub Codespaces integration for browser-based contribution"
  ],
  "publicApiSurface": [
    "GET /api/pageinfo — Page metadata endpoint",
    "GET /search — Full-text search across docs content",
    "GET /en/rest/* — Auto-generated REST API reference pages",
    "GET /en/graphql/* — GraphQL API reference pages",
    "GET /en/webhooks/* — Webhook reference pages",
    "Frontmatter: versions, title, shortTitle, intro, contentType, redirect_from",
    "Liquid tags: ifversion, data, octicon, tool, platform",
    "npm run lint-content — Content linting script",
    "npm run sync-rest — REST API documentation sync pipeline",
    "npm run sync-graphql — GraphQL documentation sync pipeline"
  ]
